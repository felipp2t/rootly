{
  "openapi": "3.0.3",
  "info": {
    "title": "Rootly API",
    "version": "0.1.0"
  },
  "components": {
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/sessions": {
      "post": {
        "operationId": "authenticateUser",
        "summary": "Authenticate User",
        "tags": [
          "Auth"
        ],
        "description": "Authenticate a user and return a JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/accounts": {
      "post": {
        "operationId": "createAccount",
        "summary": "Register User",
        "tags": [
          "Auth"
        ],
        "description": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  }
                },
                "required": [
                  "name",
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/folders": {
      "post": {
        "operationId": "createFolder",
        "summary": "Create Folder",
        "tags": [
          "Folders"
        ],
        "description": "Create a new folder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "workspaceId": {
                    "type": "string"
                  },
                  "parentId": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "workspaceId"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "get": {
        "operationId": "getFoldersByParent",
        "summary": "Get Folders",
        "tags": [
          "Folders"
        ],
        "description": "List folders by parent. Omit parentId to get root folders.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "parentId",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/items": {
      "post": {
        "operationId": "createItem",
        "summary": "Create Item",
        "tags": [
          "Items"
        ],
        "description": "Create a new item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "folderId": {
                    "type": "string"
                  },
                  "workspaceId": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "link",
                      "document",
                      "text",
                      "secret"
                    ]
                  },
                  "content": {
                    "type": "string"
                  }
                },
                "required": [
                  "title",
                  "workspaceId",
                  "type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "get": {
        "operationId": "getItemsByParent",
        "summary": "Get Items",
        "tags": [
          "Items"
        ],
        "description": "List items by parent folder. Omit parentId to get root items.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "parentId",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/tags": {
      "post": {
        "operationId": "createTag",
        "summary": "Create Tag",
        "tags": [
          "Tags"
        ],
        "description": "Create a new tag",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string",
                    "enum": [
                      "blue",
                      "green",
                      "orange",
                      "purple",
                      "red",
                      "yellow"
                    ]
                  },
                  "workspaceId": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "color",
                  "workspaceId"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/folders/{folderId}/tags/{tagId}": {
      "patch": {
        "operationId": "assignTagToFolder",
        "summary": "Assign Tag to Folder",
        "tags": [
          "Folders",
          "Tags"
        ],
        "description": "Assign an existing tag to a folder",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "folderId",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "tagId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/items/{itemId}/tags/{tagId}": {
      "patch": {
        "operationId": "assignTagToItem",
        "summary": "Assign Tag to Item",
        "tags": [
          "Items",
          "Tags"
        ],
        "description": "Assign an existing tag to an item",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "itemId",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "tagId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    }
  }
}